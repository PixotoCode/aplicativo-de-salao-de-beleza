<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Agenda do Salão</title>
<style>
body {
    font-family: Arial;
    background: #f4f4f4;
    padding: 20px;
}

h1 {
    text-align: center;
}

form {
    background: white;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 20px;
}

input {
    padding: 8px;
    margin: 5px;
}

button {
    padding: 8px 15px;
    background: #28a745;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

button:hover {
    background: #218838;
}

table {
    width: 100%;
    background: white;
    border-collapse: collapse;
}

th, td {
    padding: 10px;
    border: 1px solid #ddd;
    text-align: center;
}

.total {
    margin-top: 15px;
    font-size: 18px;
    font-weight: bold;
}
</style>
</head>
<body>

<h1>Agenda do Salão</h1>

<form id="formAgenda">
    <input type="text" id="cliente" placeholder="Nome do Cliente" required>
    <input type="text" id="servico" placeholder="Serviço" required>
    <input type="number" id="valor" placeholder="Valor (R$)" required>
    <button type="submit">Adicionar</button>
</form>

<table>
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Serviço</th>
            <th>Valor</th>
        </tr>
    </thead>
    <tbody id="lista"></tbody>
</table>

<div class="total">
    Total do Dia: R$ <span id="total">0</span>
</div>

<script>
let total = 0;

document.getElementById("formAgenda").addEventListener("submit", function(e) {
    e.preventDefault();

    const cliente = document.getElementById("cliente").value;
    const servico = document.getElementById("servico").value;
    const valor = parseFloat(document.getElementById("valor").value);

    const tabela = document.getElementById("lista");

    const linha = document.createElement("tr");
    linha.innerHTML = `
        <td>${cliente}</td>
        <td>${servico}</td>
        <td>R$ ${valor.toFixed(2)}</td>
    `;

    tabela.appendChild(linha);

    total += valor;
    document.getElementById("total").innerText = total.toFixed(2);

    document.getElementById("formAgenda").reset();
});
</script>

</body>
</html>
